{
  "rewrites": [
    {
      "source": "/malsync/(.*)",
      "destination": "https://api.malsync.moe/$1"
    },
    {
      "source": "/consumet/(.*)",
      "destination": "https://api.consumet.sh/$1"
    },
    {
      "source": "/jikan/(.*)",
      "destination": "https://api.jikan.moe/v4/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
